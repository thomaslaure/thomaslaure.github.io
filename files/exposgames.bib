@article{ABRAMSKY2026103775,
title = {Existential and positive games: a comonadic and axiomatic view},
journal = {Annals of Pure and Applied Logic},
volume = {177},
number = {9},
pages = {103775},
year = {2026},
issn = {0168-0072},
doi = {https://doi.org/10.1016/j.apal.2026.103775},
url = {https://www.sciencedirect.com/science/article/pii/S0168007226000588},
author = {Samson Abramsky and Thomas Laure and Luca Reggio},
keywords = {Logical resources, Game comonads, First-order logic, Modal logic, Existential fragments, Positive fragments},
abstract = {A number of model-comparison games central to (finite) model theory, such as pebble and Ehrenfeucht-Fraïssé games, can be captured as comonads on categories of relational structures. In particular, the coalgebras for these comonads encode in a syntax-free way preservation of resource-indexed logic fragments, such as first-order logic with bounded quantifier rank or a finite number of variables. In this paper, we extend this approach to existential and positive fragments (i.e., without universal quantifiers and without negations, respectively) of first-order and modal logic. We show, both concretely and at the axiomatic level of arboreal categories, that the preservation of existential fragments is characterised by the existence of so-called pathwise embeddings, while positive fragments are captured by a newly introduced notion of positive bisimulation. As an application, we offer a new proof of an equi-resource Lyndon positivity theorem for (multi)modal logic.}
}